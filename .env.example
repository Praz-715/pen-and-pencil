# ── Database ────────────────────────────────────────────────
# Local dev: a SQLite file. Production: Turso (libsql:// URL + token).
DATABASE_URL=file:./.data/penandpencil.db
# DATABASE_AUTH_TOKEN=        # only for Turso (libsql cloud)

# ── Better Auth ─────────────────────────────────────────────
# Generate secret: node -e "console.log(require('crypto').randomBytes(33).toString('base64'))"
BETTER_AUTH_SECRET=change-me-min-32-chars
BETTER_AUTH_URL=http://localhost:3000   # production: the deployed URL

# ── Public site URL (canonical, og:url, og:image, sitemap) ──
# Dev falls back to BETTER_AUTH_URL/localhost. Set on Vercel to the deploy URL.
# NUXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# ── Image uploads ───────────────────────────────────────────
# Dev writes to public/img/uploads. In production set this token and the
# uploader stores to Vercel Blob instead (serverless FS is read-only).
# BLOB_READ_WRITE_TOKEN=

# ── Seller seed account (single seller) ─────────────────────
SELLER_NAME=Admin Pen & Pencil
SELLER_EMAIL=penjual@penandpencil.id
SELLER_PASSWORD=change-me
