{
  "name": "pen-and-pencil",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "db:push": "drizzle-kit push --force",
    "db:studio": "drizzle-kit studio",
    "db:seed": "node --env-file=.env --import tsx scripts/seed.ts && node --env-file=.env --import tsx scripts/seed-products.ts",
    "db:seed:demo": "node --env-file=.env --import tsx scripts/seed-demo.ts",
    "og:gen": "node --env-file=.env --import tsx scripts/gen-og.ts",
    "db:push:prod": "node --env-file=.env.production ./node_modules/drizzle-kit/bin.cjs push --force",
    "db:seed:prod": "node --env-file=.env.production --import tsx scripts/seed.ts && node --env-file=.env.production --import tsx scripts/seed-products.ts && node --env-file=.env.production --import tsx scripts/seed-demo.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "@vercel/blob": "^2.4.0",
    "better-auth": "^1.6.18",
    "drizzle-orm": "^0.45.2",
    "nuxt": "^4.0.0",
    "sharp": "^0.35.1",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@nuxt/fonts": "^0.11.0",
    "@tailwindcss/vite": "^4.1.0",
    "drizzle-kit": "^0.31.10",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.22.4"
  }
}
